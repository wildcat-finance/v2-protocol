# -----------------------------------------------------------------------------
# Active protocol deployment environment
# -----------------------------------------------------------------------------

# RPC endpoint used by forge script commands and JS deployment helpers.
RPC_URL=

# Deployment network name used to resolve deployments/<network>/deployments.json.
# Set this explicitly for local/custom networks such as an Anvil fork.
DEPLOYMENTS_NETWORK=

# Use the deployment-style profile for size-sensitive deploys.
FOUNDRY_PROFILE=ir

# -----------------------------------------------------------------------------
# Deployer key selection
# -----------------------------------------------------------------------------

# Default private key env var consumed by the active forge deploy scripts.
PVT_KEY=

# Optional override if you want the scripts to read a different env var name
# instead of PVT_KEY.
DEPLOYER_PRIVATE_KEY_VAR=PVT_KEY

# -----------------------------------------------------------------------------
# Deploy behavior flags
# -----------------------------------------------------------------------------

# When true, active deploy scripts will redeploy instead of reusing existing
# deployments recorded under the relevant deployment key(s).
OVERRIDE_EXISTING=false

# Required by DeployMarketLens to version the immutable lens set safely.
# Example: sepolia-2026-04-17 or v2_5_rc1
MARKET_LENS_DEPLOYMENT_LABEL=

# -----------------------------------------------------------------------------
# Optional address overrides
# -----------------------------------------------------------------------------

# If unset, active deploy scripts fall back to deployments/<network>/deployments.json.
ARCH_CONTROLLER=
SANCTIONS_SENTINEL=

# Should remain the legacy HooksFactory for backward-compatible default lens behavior
# unless you intentionally want a different default-factory scope.
DEFAULT_HOOKS_FACTORY=

# -----------------------------------------------------------------------------
# Optional JS helper overrides
# -----------------------------------------------------------------------------

# Template sync / handoff helper overrides.
LEGACY_HOOKS_FACTORY=
REVOLVING_HOOKS_FACTORY=

# The JS template sync helper also accepts these key vars in addition to PVT_KEY.
DEPLOYER_PRIVATE_KEY=
PRIVATE_KEY=
