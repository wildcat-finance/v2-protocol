{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildcat.finance/schemas/rcf-v2-handoff.schema.json",
  "title": "RCF V2 Phase 1 Handoff Artifact",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "chain",
    "addresses",
    "txHashes",
    "routing",
    "abiSurface",
    "sources"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "chain": {
      "type": "object",
      "required": [
        "id",
        "network",
        "canonicalName"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "network": {
          "type": "string",
          "minLength": 1
        },
        "canonicalName": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "addresses": {
      "type": "object",
      "required": [
        "archController",
        "hooksFactoryLegacy",
        "hooksFactoryRevolving",
        "marketLensLatest",
        "marketLensCore",
        "marketLensAggregator",
        "marketLensLive",
        "wildcatMarketRevolvingInitCodeStorage"
      ],
      "properties": {
        "archController": {
          "$ref": "#/$defs/address"
        },
        "hooksFactoryLegacy": {
          "$ref": "#/$defs/address"
        },
        "hooksFactoryRevolving": {
          "$ref": "#/$defs/address"
        },
        "marketLensLatest": {
          "$ref": "#/$defs/address"
        },
        "marketLensCore": {
          "$ref": "#/$defs/address"
        },
        "marketLensAggregator": {
          "$ref": "#/$defs/address"
        },
        "marketLensLive": {
          "$ref": "#/$defs/address"
        },
        "wildcatMarketRevolvingInitCodeStorage": {
          "$ref": "#/$defs/address"
        }
      },
      "additionalProperties": false
    },
    "txHashes": {
      "type": "object",
      "required": [
        "deployHooksFactoryRevolving",
        "registerControllerFactory",
        "registerWithArchController",
        "deployMarketLensCore",
        "deployMarketLensAggregator",
        "deployMarketLensLive",
        "deployMarketLens"
      ],
      "properties": {
        "deployHooksFactoryRevolving": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "registerControllerFactory": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "registerWithArchController": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "deployMarketLensCore": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "deployMarketLensAggregator": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "deployMarketLensLive": {
          "$ref": "#/$defs/nullableTxHash"
        },
        "deployMarketLens": {
          "$ref": "#/$defs/nullableTxHash"
        }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "required": [
        "defaultMarketType",
        "factoryByMarketType",
        "marketTypeByFactory",
        "latestLens"
      ],
      "properties": {
        "defaultMarketType": {
          "const": "legacy"
        },
        "factoryByMarketType": {
          "type": "object",
          "required": [
            "legacy",
            "revolving"
          ],
          "properties": {
            "legacy": {
              "$ref": "#/$defs/address"
            },
            "revolving": {
              "$ref": "#/$defs/address"
            }
          },
          "additionalProperties": false
        },
        "marketTypeByFactory": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "legacy",
              "revolving"
            ]
          }
        },
        "latestLens": {
          "$ref": "#/$defs/address"
        }
      },
      "additionalProperties": false
    },
    "abiSurface": {
      "type": "object",
      "required": [
        "artifacts",
        "selectors",
        "notes"
      ],
      "properties": {
        "artifacts": {
          "type": "object",
          "required": [
            "hooksFactoryLegacy",
            "hooksFactoryRevolving",
            "marketLens",
            "marketLensCore",
            "marketLensAggregator",
            "marketLensLive",
            "wildcatMarketRevolving"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "selectors": {
          "type": "object",
          "required": [
            "hooksFactoryRevolving",
            "marketLens",
            "wildcatMarketRevolving",
            "events"
          ],
          "properties": {
            "hooksFactoryRevolving": {
              "type": "object",
              "required": [
                "deployMarket",
                "deployMarketAndHooks"
              ],
              "properties": {
                "deployMarket": {
                  "$ref": "#/$defs/selector"
                },
                "deployMarketAndHooks": {
                  "$ref": "#/$defs/selector"
                }
              },
              "additionalProperties": {
                "$ref": "#/$defs/selector"
              }
            },
            "marketLens": {
              "type": "object",
              "required": [
                "getMarketDataV2",
                "getMarketsDataV2",
                "getAllMarketsDataV2ForHooksTemplate",
                "getAggregatedAllMarketsDataV2ForHooksTemplate",
                "getMarketsLiveDataV2",
                "getMarketsLiveDataWithLenderStatusV2"
              ],
              "properties": {
                "getMarketDataV2": {
                  "$ref": "#/$defs/selector"
                },
                "getMarketsDataV2": {
                  "$ref": "#/$defs/selector"
                },
                "getAllMarketsDataV2ForHooksTemplate": {
                  "$ref": "#/$defs/selector"
                },
                "getAggregatedAllMarketsDataV2ForHooksTemplate": {
                  "$ref": "#/$defs/selector"
                },
                "getMarketsLiveDataV2": {
                  "$ref": "#/$defs/selector"
                },
                "getMarketsLiveDataWithLenderStatusV2": {
                  "$ref": "#/$defs/selector"
                }
              },
              "additionalProperties": {
                "$ref": "#/$defs/selector"
              }
            },
            "wildcatMarketRevolving": {
              "type": "object",
              "required": [
                "commitmentFeeBips",
                "drawnAmount"
              ],
              "properties": {
                "commitmentFeeBips": {
                  "$ref": "#/$defs/selector"
                },
                "drawnAmount": {
                  "$ref": "#/$defs/selector"
                }
              },
              "additionalProperties": {
                "$ref": "#/$defs/selector"
              }
            },
            "events": {
              "type": "object",
              "required": [
                "marketDeployedTopic0"
              ],
              "properties": {
                "marketDeployedTopic0": {
                  "$ref": "#/$defs/topic"
                }
              },
              "additionalProperties": {
                "$ref": "#/$defs/topic"
              }
            }
          },
          "additionalProperties": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "required": [
        "deploymentsFile",
        "hooksBroadcast",
        "lensBroadcast",
        "hooksScriptName",
        "lensScriptName"
      ],
      "properties": {
        "deploymentsFile": {
          "type": "string"
        },
        "hooksBroadcast": {
          "type": [
            "string",
            "null"
          ]
        },
        "lensBroadcast": {
          "type": [
            "string",
            "null"
          ]
        },
        "hooksScriptName": {
          "type": "string"
        },
        "lensScriptName": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "txHash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "selector": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{8}$"
    },
    "topic": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "nullableTxHash": {
      "anyOf": [
        {
          "$ref": "#/$defs/txHash"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
